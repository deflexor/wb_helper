# =============================================================================
# wbhelper - Environment Variables Configuration
# =============================================================================
# Copy this file to .env and fill in the values
# All secrets must be provided via environment variables - no hardcoding
# =============================================================================

# -----------------------------------------------------------------------------
# Required: Authentication & Security
# -----------------------------------------------------------------------------

# JWT signing secret (minimum 32 characters / 256 bits for secure HMAC-SHA256)
# Generate with: openssl rand -base64 48
JWT_SECRET=your-secure-jwt-secret-min-32-chars

# -----------------------------------------------------------------------------
# Required: Database
# -----------------------------------------------------------------------------

# Path to SQLite database file
DATABASE_PATH=/data/wbhelper.db

# -----------------------------------------------------------------------------
# Optional: API Keys (Marketplace & AI)
# -----------------------------------------------------------------------------

# OpenRouter API key for AI features (get from https://openrouter.ai/)
# OPENROUTER_API_KEY=sk-or-v1-...

# Wildberries API key (if using WB integration)
# WB_API_KEY=your-wb-api-key

# Ozon API key (if using Ozon integration)
# OZON_API_KEY=your-ozon-api-key

# -----------------------------------------------------------------------------
# Optional: Server Configuration
# -----------------------------------------------------------------------------

# Server port (default: 8080)
PORT=8080

# Logging level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Security Notes:
# - Never commit .env to version control
# - Use strong random values for JWT_SECRET (at least 32 characters)
# - Rotate secrets periodically in production
# - Use different secrets for dev/staging/production environments
# -----------------------------------------------------------------------------
